{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "realitech-ads",
  "compatibility_date": "2026-06-01",
  // Static landing page served via Workers static assets (no Worker code).
  "assets": { "directory": "./public" },
  // Custom domain — wrangler provisions DNS + cert on deploy.
  "routes": [{ "pattern": "ads.realitech.vn", "custom_domain": true }]
}
